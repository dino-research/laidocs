# LAIDocs Backend Configuration
# This file is loaded by pydantic-settings in backend/core/config.py

# URL of the Telemetry Server (Change this in production)
TELEMETRY_URL="http://localhost:8001/api/v1/track"

# Enable or disable telemetry tracking
TELEMETRY_ENABLED=true

# Default LLM Provider Configuration
# Used when users have not configured their own model in Settings.
DEFAULT_LLM_BASE_URL="https://api.openai.com/v1"
DEFAULT_LLM_API_KEY="sk-..."
DEFAULT_LLM_MODEL="gpt-4o"
